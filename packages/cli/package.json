{
	"name": "aegis",
	"version": "0.1.0",
	"description": "CLI for Aegis — context infrastructure engine for AI coding agents",
	"type": "module",
	"bin": {
		"aegis": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aegis/core": "workspace:*",
		"@aegis/engine": "workspace:*",
		"@aegis/storage": "workspace:*",
		"@aegis/adapters": "workspace:*",
		"@aegis/server": "workspace:*"
	},
	"license": "Apache-2.0"
}
