{
	"name": "aegisctx",
	"version": "0.1.0",
	"description": "CLI for aegisctx — context infrastructure engine for AI coding agents",
	"type": "module",
	"bin": {
		"aegisctx": "./dist/bin.js"
	},
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/bin.ts src/index.ts --format esm --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aegisctx/core": "workspace:*",
		"@aegisctx/engine": "workspace:*",
		"@aegisctx/storage": "workspace:*",
		"@aegisctx/adapters": "workspace:*",
		"@aegisctx/server": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.10.5"
	},
	"license": "Apache-2.0"
}
