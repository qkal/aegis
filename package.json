{
	"name": "aegis-monorepo",
	"private": true,
	"version": "0.0.0",
	"description": "Security-first, local-first context infrastructure engine for AI coding agents",
	"license": "Apache-2.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=9.0.0"
	},
	"packageManager": "pnpm@9.15.4",
	"scripts": {
		"build": "pnpm -r run build",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:core": "node ./scripts/ci/run-vitest-shard.mjs core",
		"test:storage": "node ./scripts/ci/run-vitest-shard.mjs storage",
		"test:rest": "node ./scripts/ci/run-vitest-shard.mjs rest",
		"test:ci": "vitest run --reporter=default --reporter=junit --outputFile=test-report.junit.xml",
		"bench": "vitest run --config vitest.bench.config.ts",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"typecheck": "pnpm -r run typecheck",
		"clean": "pnpm -r run clean",
		"doctor": "pnpm -r run build && node packages/cli/dist/cli.js doctor",
		"ci:smoke": "node ./scripts/ci/smoke.mjs",
		"ci:hygiene": "node ./scripts/ci/hygiene.mjs"
	},
	"devDependencies": {
		"@dprint/json": "^0.21.3",
		"@dprint/markdown": "^0.21.1",
		"@dprint/typescript": "^0.95.15",
		"@vitest/coverage-v8": "^4.1.4",
		"dprint": "^0.54.0",
		"oxlint": "^1.60.0",
		"tsup": "^8.5.1",
		"typescript": "^5.7.3",
		"vitest": "^4.1.4"
	}
}
