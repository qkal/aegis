{
	"name": "@aegis/adapters",
	"version": "0.1.0",
	"description": "Platform-specific adapters: Claude Code, Cursor, Gemini CLI, VS Code Copilot",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aegis/core": "workspace:*"
	},
	"license": "Apache-2.0"
}
