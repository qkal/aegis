{
	"$schema": "https://aegis.dev/schema/config.json",
	"version": 1,
	"platform": "amp",
	"tools": {
		"deny": [
			"Bash(sudo *)",
			"Bash(rm -rf *)",
			"Bash(chmod *777*)",
			"Bash(chmod *-R*)",
			"Bash(chmod *a+*)",
			"Bash(chmod *o+w*)",
			"Bash(chown *)",
			"Read(.env*)",
			"Read(~/.ssh/*)",
			"Read(~/.aws/*)"
		],
		"allow": [
			"Bash(git *)",
			"Bash(npm *)",
			"Bash(pnpm *)",
			"Bash(yarn *)",
			"Bash(bun *)",
			"Bash(node *)",
			"Bash(python *)",
			"Bash(pip *)"
		],
		"ask": []
	},
	"sandbox": {
		"env": {
			"allow": ["PATH", "HOME", "LANG", "TERM"],
			"deny": [
				"AWS_*",
				"GH_TOKEN",
				"GITHUB_TOKEN",
				"OPENAI_API_KEY",
				"ANTHROPIC_API_KEY",
				"GOOGLE_API_KEY",
				"SSH_AUTH_SOCK"
			]
		},
		"fs": {
			"read": [],
			"write": [],
			"deny": [
				"~/.ssh/*",
				"~/.aws/*",
				"~/.gnupg/*",
				"~/.config/gcloud/*",
				"~/.config/credentials/*",
				".env*"
			]
		},
		"net": {
			"allow": [],
			"deny": ["*"]
		}
	},
	"execution": {
		"maxTimeoutMs": 30000,
		"maxOutputBytes": 5242880,
		"allowBackground": false,
		"allowedRuntimes": [
			"javascript",
			"typescript",
			"python",
			"shell",
			"ruby",
			"go",
			"rust",
			"php",
			"r",
			"perl",
			"swift"
		]
	},
	"storage": {
		"urlTtl": "24h",
		"staleCleanupDays": 14
	},
	"updates": {
		"checkOnStart": false
	},
	"amp": {
		"_comment": "Amp has no public hook API as of 2026-04. This adapter is Tier 3 (MCP-only). Policy is enforced inside the MCP tool wrapper. Routing is steered by .amp/AGENTS.md installed by `aegisctx init amp`.",
		"settingsLocations": ["~/.amp/settings.json", ".amp/settings.json"],
		"agentsFile": ".amp/AGENTS.md"
	}
}
